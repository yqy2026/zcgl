# ============================================
# Backend-specific Git Ignore Rules
# Land Property Asset Management System
# ============================================

# Note: Most rules are inherited from root .gitignore
# This file only contains backend-specific additions

# Alembic - ignore temp migration files but keep structure
# Note: We keep alembic/versions/*.py for version control
alembic/versions/*.pyc

# Backend coverage reports
htmlcov/

# Development database
land_property.db

# Temporary files (IDE/tool generated)
src/api/v1/tmpclaude-*-cwd
