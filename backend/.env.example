# =============================================
# 土地物业资产管理系统 - 环境配置模板
# Land Property Asset Management System - Environment Config Template
# =============================================
# 复制此文件为 .env 并填入实际值
# Copy this file to .env and fill in actual values

# =============================================
# 应用环境配置 (Application Environment)
# =============================================
# 环境类型: production, development, testing, staging
# 默认: production (如未设置)
# Environment type: production, development, testing, staging
# Default: production (if not set)
ENVIRONMENT=development

# =============================================
# 服务端口配置 (Server Port Configuration)
# =============================================
# 后端服务监听地址与端口
HOST=0.0.0.0
PORT=8002
# run_dev.py / make dev-backend 优先使用 API_PORT
API_PORT=8002

# =============================================
# 安全配置 (Security Configuration)
# =============================================
# ============================================================================
# SECURITY CRITICAL: Generate strong secrets before running in production!
# ============================================================================
# Generate SECRET_KEY with:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
# Generate DATA_ENCRYPTION_KEY with (standard Base64 + version):
# cd backend && python -m src.core.encryption
# NOTE: Do NOT use secrets.token_urlsafe for DATA_ENCRYPTION_KEY (will cause Incorrect padding).

SECRET_KEY="REPLACE-WITH-SECURE-SECRET-KEY"
DATA_ENCRYPTION_KEY="<base64_key>:1"
# 强制要求 DATA_ENCRYPTION_KEY（生产环境建议 true；开发可改为 false）
REQUIRE_ENCRYPTION=true

# ⚠️  SECURITY WARNINGS:
# • Never commit these values to version control
# • Use different keys for development, staging, and production
# • Rotate keys periodically (every 90 days recommended)
# • Store production keys in a secure secrets manager (AWS KMS, HashiCorp Vault, etc.)
# • If these keys are leaked, immediately regenerate and rotate all encrypted data

# 可选: 自定义JWT配置 / Optional: Custom JWT configuration
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120
# JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# 可选: CSRF 配置 / Optional: CSRF configuration
# CSRF_ENABLED=true
# CSRF_SAMESITE=strict  # lax | strict | none
# CSRF_COOKIE_NAME=csrf_token
# CSRF_HEADER_NAME=X-CSRF-Token

# 可选: IP 黑名单 / Optional: IP blacklist
# IP_BLACKLIST=["192.0.2.1","198.51.100.10"]
# IP_AUTO_BLOCK_ENABLED=true
# IP_AUTO_BLOCK_THRESHOLD=10
# IP_AUTO_BLOCK_DURATION=3600

# 可选: 安全分析器 / Optional: security analyzer
# SECURITY_ANALYZER_ENABLED=true
# SECURITY_ANALYZER_ENABLE_IP_BLOCK=true
# SECURITY_ANALYZER_MAX_SUSPICIOUS_REQUESTS=5
# SECURITY_ANALYZER_BLOCK_DURATION=3600
# SECURITY_ANALYZER_PATTERNS=["<script","union\\s+select"]

# 可选: 自适应限流 / Optional: adaptive rate limit
# ADAPTIVE_RATE_LIMIT_ENABLED=true
# ADAPTIVE_RATE_LIMIT_MAX_ERROR_RATE=0.3
# ADAPTIVE_RATE_LIMIT_SUSPICIOUS_MAX_ERROR_RATE=0.1
# ADAPTIVE_RATE_LIMIT_RESET_SECONDS=60

# 可选: 请求限制 / Optional: request limiter
# REQUEST_LIMIT_ENABLED=true
# REQUEST_LIMIT_MAX_REQUESTS_PER_MINUTE=100
# REQUEST_LIMIT_RESET_SECONDS=60

# 可选: 安全中间件 / Optional: security middleware
# SECURITY_MIDDLEWARE_ENABLED=true
# SECURITY_MIDDLEWARE_IP_BLACKLIST_ENABLED=true
# SECURITY_MIDDLEWARE_RATE_LIMIT_ENABLED=true
# SECURITY_MIDDLEWARE_USER_AGENT_CHECK_ENABLED=true
# SECURITY_MIDDLEWARE_USER_AGENT_MIN_LENGTH=10
# SECURITY_MIDDLEWARE_RATE_LIMITS={"api":{"requests":1000,"window":3600},"upload":{"requests":50,"window":3600}}

# 可选: Sentry APM / Error Tracking
# SENTRY_ENABLED=false
# SENTRY_DSN=""
# SENTRY_ENVIRONMENT=development
# SENTRY_TRACES_SAMPLE_RATE=0.0
# SENTRY_PROFILES_SAMPLE_RATE=0.0
# SENTRY_SEND_DEFAULT_PII=false

# =============================================
# LLM / Vision 配置 (LLM & Vision Configuration)
# =============================================
# LLM_PROVIDER 用于文档提取（Vision）以及部分文本 LLM 能力
# 推荐使用提供商名: qwen | glm | deepseek | hunyuan
# 兼容别名: glm-4v / qwen-vl-max / deepseek-vl 等（会自动归一化）
LLM_PROVIDER="hunyuan"

# 可选：仅文档提取使用不同提供商（覆盖 LLM_PROVIDER）
# EXTRACTION_LLM_PROVIDER="qwen"

# =============================================
# 阿里通义千问 Qwen-VL (推荐)
# =============================================
# 获取API Key: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY="your-dashscope-api-key"
# DASHSCOPE_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
QWEN_VISION_MODEL="qwen3-vl-flash"
QWEN_TIMEOUT=120
# 文本模型（LLMService，可选）
# DASHSCOPE_MODEL="qwen-max"

# =============================================
# 智谱AI GLM-4V (免费/备选)
# =============================================
# 获取API Key: https://open.bigmodel.cn/
# ZHIPU_API_KEY="your-zhipu-api-key"
# ZHIPU_BASE_URL="https://open.bigmodel.cn/api/paas/v4"
# ZHIPU_VISION_MODEL="glm-4v"
# ZHIPU_TIMEOUT=120
# 文本模型（LLMService，可选）
# ZHIPU_MODEL="GLM-4-Flash"

# =============================================
# 腾讯混元 Vision (备选)
# =============================================
# 获取API Key: https://console.cloud.tencent.com/hunyuan
# HUNYUAN_API_KEY="your-hunyuan-api-key"
# HUNYUAN_BASE_URL="https://api.hunyuan.cloud.tencent.com/v1"
# HUNYUAN_VISION_MODEL="hunyuan-vision"
# HUNYUAN_TIMEOUT=120
# 文本模型（LLMService，可选）
# HUNYUAN_MODEL="hunyuan-vision"

# =============================================
# 深度求索 DeepSeek-VL (不推荐)
# =============================================
# 获取API Key: https://platform.deepseek.com/
# DEEPSEEK_API_KEY="your-deepseek-api-key"
# DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"
# DEEPSEEK_VISION_MODEL="deepseek-vl"
# DEEPSEEK_TIMEOUT=120

# =============================================
# 通用文本 LLM（LLMService，仅少量功能使用，可忽略）
# =============================================
# LLM_API_KEY="your-llm-api-key"
# LLM_BASE_URL="https://api.openai.com/v1"
# LLM_MODEL="gpt-4o-mini"
# LLM_TIMEOUT=60

# =============================================
# 数据库配置 (Database Configuration)
# =============================================
#
# 开发环境 / Development Environment:
#   - ⚠️ 必须设置 DATABASE_URL 为 PostgreSQL
#   - SQLite 已移除
#
# 生产环境 / Production Environment:
#   - ⚠️ 必须设置 DATABASE_URL 为 PostgreSQL
#   - 必须使用 PostgreSQL + psycopg 驱动
#
# 格式说明 / Format:
#   PostgreSQL: postgresql+psycopg://user:password@host:port/database
#
# 示例配置 / Examples:

# 1. PostgreSQL (推荐用于生产 / Recommended for production)
# DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/zcgl_db
# DATABASE_URL=postgresql+psycopg://zcgl_user:secure_password@db.example.com:5432/zcgl_prod

DATABASE_URL=postgresql+psycopg://USERNAME:PASSWORD@localhost:5432/zcgl
TEST_DATABASE_URL=postgresql+psycopg://USERNAME:PASSWORD@localhost:5432/zcgl_test

# SQLite 已移除，不支持任何环境使用

# 2. 使用单独的环境变量配置 PostgreSQL / Alternative: Individual env vars
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=your-password
# PGDATABASE=zcgl_db
#
# 注意: 如果设置了 DATABASE_URL，单独的环境变量将被忽略
# Note: If DATABASE_URL is set, individual env vars are ignored

# 数据库连接池配置 / Connection Pool Configuration (Optional)
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10
# DB_POOL_TIMEOUT=30
# DB_POOL_RECYCLE=3600

# =============================================
# Redis 缓存配置 (Redis Cache Configuration)
# =============================================
# 默认启用 Redis，不可用时自动降级为内存缓存
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=""

# =============================================
# 依赖策略配置 (Dependency Policy Configuration)
# =============================================
# 控制可选依赖缺失时的行为 / Control behavior when optional dependencies are missing
#
# 可选值 / Options:
#   - strict: 可选依赖缺失时生产环境失败 (默认生产环境)
#   - graceful: 可选依赖缺失时优雅降级 (默认开发环境)
#   - optional: 可选依赖被视为可选，不记录警告
# DEPENDENCY_POLICY=graceful
