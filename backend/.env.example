# =============================================
# 土地物业资产管理系统 - 环境配置模板
# Land Property Asset Management System - Environment Config Template
# =============================================
# 复制此文件为 .env 并填入实际值
# Copy this file to .env and fill in actual values

# =============================================
# 应用环境配置 (Application Environment)
# =============================================
# 环境类型: production, development, testing, staging
# 默认: production (如未设置)
# Environment type: production, development, testing, staging
# Default: production (if not set)
ENVIRONMENT=development

# =============================================
# 安全配置 (Security Configuration)
# =============================================
# JWT密钥 - 用于签名和验证JWT令牌
# JWT Secret Key - Used to sign and verify JWT tokens
#
# ⚠️ 生产环境必须使用32+字符的强随机字符串
# Production environment MUST use a strong random string with 32+ characters
#
# 生成方法 / Generate method:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# 示例格式 / Example format (DO NOT USE IN PRODUCTION):
# SECRET_KEY=your-generated-secret-key-here-minimum-32-characters
SECRET_KEY=your-secret-key-min-32-chars-change-this-in-production

# 可选: 自定义JWT配置 / Optional: Custom JWT configuration
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120
# JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================
# 多模型提供商选择 (Multi-Model Provider Selection)
# =============================================
# 可选值: glm-4v (默认), qwen-vl-max, deepseek-vl
LLM_PROVIDER="glm-4v"

# =============================================
# 智谱AI GLM-4V Configuration (默认)
# =============================================
# 获取API Key: https://open.bigmodel.cn/
ZHIPU_API_KEY="your-zhipu-api-key"
# ZHIPU_BASE_URL="https://open.bigmodel.cn/api/paas/v4"
ZHIPU_VISION_MODEL="glm-4v"
ZHIPU_TIMEOUT=120

# 文本模型 (用于 LLMService)
LLM_MODEL="GLM-4-Flash"
LLM_API_KEY="${ZHIPU_API_KEY}"
LLM_BASE_URL="https://open.bigmodel.cn/api/paas/v4/"

# =============================================
# 阿里通义千问 Qwen-VL Configuration
# =============================================
# 获取API Key: https://dashscope.console.aliyun.com/
# DASHSCOPE_API_KEY="your-dashscope-api-key"
# DASHSCOPE_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
# QWEN_VISION_MODEL="qwen-vl-max"
# QWEN_TIMEOUT=120

# =============================================
# 深度求索 DeepSeek-VL Configuration
# =============================================
# 获取API Key: https://platform.deepseek.com/
# DEEPSEEK_API_KEY="your-deepseek-api-key"
# DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"
# DEEPSEEK_VISION_MODEL="deepseek-vl"
# DEEPSEEK_TIMEOUT=120

# =============================================
# 数据加密配置 (Data Encryption Configuration)
# =============================================
# 敏感数据加密密钥（32+ 字节，base64编码）
# 格式: {base64_key}:{version}
# 生成命令: python -m src.core.encryption
#
# 示例（不要在生产环境使用）:
# DATA_ENCRYPTION_KEY="MTIzNDU2Nzg5MDEyMzQ1Njc4OTAxMjM0NTY3ODkwMTIz:1"
#
# ⚠️ 生产环境警告:
# - 使用强随机密钥生成器
# - 通过安全渠道分发 (AWS KMS, HashiCorp Vault, etc.)
# - 定期轮换密钥（递增版本号）
# - 永远不要将密钥提交到版本控制
# - 不同环境使用不同密钥 (开发/测试/生产)
DATA_ENCRYPTION_KEY=""

# =============================================
# 数据库配置 (Database Configuration)
# =============================================
#
# 开发环境 / Development Environment:
#   - 可选设置 DATABASE_URL (默认使用 SQLite)
#   - SQLite 仅用于开发和测试，不应用于生产
#
# 生产环境 / Production Environment:
#   - ⚠️ 必须设置 DATABASE_URL 为 PostgreSQL
#   - ⚠️ SQLite 在生产环境将被拒绝
#   - 必须使用 PostgreSQL + psycopg2 驱动
#
# 格式说明 / Format:
#   PostgreSQL: postgresql://user:password@host:port/database
#   PostgreSQL+psycopg: postgresql+psycopg://user:password@host:port/database
#
# 示例配置 / Examples:

# 1. PostgreSQL (推荐用于生产 / Recommended for production)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/zcgl_db
# DATABASE_URL=postgresql+psycopg://zcgl_user:secure_password@db.example.com:5432/zcgl_prod

# 2. SQLite (仅用于开发 / Development only)
# DATABASE_URL=sqlite:///./data/land_property.db

# 3. 使用单独的环境变量配置 PostgreSQL / Alternative: Individual env vars
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=your-password
# PGDATABASE=zcgl_db
#
# 注意: 如果设置了 DATABASE_URL，单独的环境变量将被忽略
# Note: If DATABASE_URL is set, individual env vars are ignored

# 数据库连接池配置 / Connection Pool Configuration (Optional)
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10
# DB_POOL_TIMEOUT=30
# DB_POOL_RECYCLE=3600

# =============================================
# 依赖策略配置 (Dependency Policy Configuration)
# =============================================
# 控制可选依赖缺失时的行为 / Control behavior when optional dependencies are missing
#
# 可选值 / Options:
#   - strict: 可选依赖缺失时生产环境失败 (默认生产环境)
#   - graceful: 可选依赖缺失时优雅降级 (默认开发环境)
#   - optional: 可选依赖被视为可选，不记录警告
# DEPENDENCY_POLICY=graceful
