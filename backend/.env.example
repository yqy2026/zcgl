# =============================================
# 土地物业资产管理系统 - 环境配置模板
# Land Property Asset Management System - Environment Config Template
# =============================================
# 复制此文件为 .env 并填入实际值
# Copy this file to .env and fill in actual values

# =============================================
# Database Configuration (PostgreSQL)
# =============================================
# Main Database
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/zcgl_db"

# Test Database (optional, for automated testing)
# TEST_DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/zcgl_test"

# Connection Pool Settings (optional - defaults in database.py are good)
# DATABASE_POOL_SIZE=20
# DATABASE_MAX_OVERFLOW=30
# DATABASE_POOL_TIMEOUT=30
# DATABASE_POOL_RECYCLE=3600
# DATABASE_POOL_PRE_PING=true

# =============================================
# 多模型提供商选择 (Multi-Model Provider Selection)
# =============================================
# 可选值: glm-4v (默认), qwen-vl-max, deepseek-vl
LLM_PROVIDER="glm-4v"

# =============================================
# 智谱AI GLM-4V Configuration (默认)
# =============================================
# 获取API Key: https://open.bigmodel.cn/
ZHIPU_API_KEY="your-zhipu-api-key"
# ZHIPU_BASE_URL="https://open.bigmodel.cn/api/paas/v4"
ZHIPU_VISION_MODEL="glm-4v"
ZHIPU_TIMEOUT=120

# 文本模型 (用于 LLMService)
LLM_MODEL="GLM-4-Flash"
LLM_API_KEY="${ZHIPU_API_KEY}"
LLM_BASE_URL="https://open.bigmodel.cn/api/paas/v4/"

# =============================================
# 阿里通义千问 Qwen-VL Configuration
# =============================================
# 获取API Key: https://dashscope.console.aliyun.com/
# DASHSCOPE_API_KEY="your-dashscope-api-key"
# DASHSCOPE_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
# QWEN_VISION_MODEL="qwen-vl-max"
# QWEN_TIMEOUT=120

# =============================================
# 深度求索 DeepSeek-VL Configuration
# =============================================
# 获取API Key: https://platform.deepseek.com/
# DEEPSEEK_API_KEY="your-deepseek-api-key"
# DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"
# DEEPSEEK_VISION_MODEL="deepseek-vl"
# DEEPSEEK_TIMEOUT=120
