# ==========================================
# 土地物业资产管理系统 - 环境变量配置示例
# ==========================================
# 复制此文件为 .env 并修改相应的值

# ==========================================
# 数据库配置 (必填)
# ==========================================
# PostgreSQL连接URL (生产环境推荐)
DATABASE_URL=postgresql://zcgl_user:zcgl_password@localhost:5432/zcgl_db
# 或 SQLite连接URL (开发环境)
# DATABASE_URL=sqlite:///./data/land_property.db

# 是否打印SQL语句 (开发环境可设为true)
DATABASE_ECHO=false

# ==========================================
# API服务配置
# ==========================================
# API服务器主机地址
API_HOST=0.0.0.0

# API服务器端口 (必填)
API_PORT=8002

# API标题
API_TITLE=Land Property Asset Management API

# ==========================================
# 安全配置 (必填 - 生产环境必须修改)
# ==========================================
# JWT密钥 - 生产环境必须使用强随机字符串
# 生成方法: python -c "import secrets; print(secrets.token_urlsafe(32))"
# 示例 (请替换为你自己的密钥):
SECRET_KEY=ascFE1md30fOoVpS6_AP3Vof4lLMyVDQMLqnFXj9-bw

# JWT算法
ALGORITHM=HS256

# 访问令牌过期时间(分钟)
ACCESS_TOKEN_EXPIRE_MINUTES=120

# ==========================================
# CORS配置
# ==========================================
# 允许的跨域源，多个源用逗号分隔
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ==========================================
# Redis配置 (可选)
# ==========================================
# Redis连接URL
REDIS_URL=redis://localhost:6379/0

# 是否启用缓存
CACHE_ENABLED=false

# 缓存过期时间(秒)
CACHE_TTL_SECONDS=3600

# ==========================================
# 文件上传配置
# ==========================================
# 文件上传最大大小(MB)
UPLOAD_MAX_SIZE_MB=50

# 允许上传的文件扩展名，逗号分隔
UPLOAD_ALLOWED_EXTENSIONS=xlsx,xls,pdf,doc,docx

# ==========================================
# Excel处理配置
# ==========================================
# Excel处理批次大小
EXCEL_BATCH_SIZE=1000

# Excel处理超时时间(秒)
EXCEL_TIMEOUT_SECONDS=300

# ==========================================
# 任务处理配置
# ==========================================
# 任务最大重试次数
TASK_MAX_RETRIES=3

# 任务记录保留天数
TASK_RETENTION_DAYS=30

# ==========================================
# 日志配置
# ==========================================
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=logs/app.log

# ==========================================
# OCR配置 (可选)
# ==========================================
# OCR引擎提供者: optimized, paddle
OCR_ENGINE_PROVIDER=optimized

# PaddleOCR 参数开关（与代码兼容）
# 语言：中文为 ch
OCR_LANG=ch
# 是否使用GPU（无GPU则保持false）
OCR_USE_GPU=false
# CPU加速：启用MKLDNN（若报Unknown argument将自动回退）
OCR_ENABLE_MKLDNN=true
# 文本行方向分类（新参数，优先使用）
OCR_USE_TEXTLINE_ORIENTATION=true
# 旧参数备用：use_angle_cls（代码会自动兼容）
OCR_USE_ANGLE_CLS=true
# 检测和识别相关阈值/批量（可选）
OCR_DET_DB_THRESH=0.3
OCR_DET_LIMIT_SIDE_LEN=960
OCR_REC_BATCH_NUM=64
OCR_DROP_SCORE=0.1

# ==========================================
# 环境配置
# ==========================================
# 运行环境: production, development, testing, staging
ENVIRONMENT=development

# 依赖导入策略: strict, graceful, optional
# strict: 关键依赖缺失时报错（推荐用于生产和开发）
# graceful: 关键依赖缺失时警告并降级（推荐用于测试）
# optional: 依赖缺失时静默降级
DEPENDENCY_POLICY=strict

# 调试模式 (已弃用，请使用 ENVIRONMENT)
DEBUG=false

# 开发模式 (已弃用，请使用 ENVIRONMENT)
DEV_MODE=false

# 测试模式 (已弃用，请使用 ENVIRONMENT=testing)
TESTING_MODE=false

# ==========================================
# 配置文件路径 (可选)
# ==========================================
# YAML配置文件路径，留空则使用默认路径
# CONFIG_FILE=config.yaml
