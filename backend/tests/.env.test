# Test Environment Configuration
# This file is automatically loaded by pytest conftest

# Core Settings
ENVIRONMENT=testing
DEPENDENCY_POLICY=graceful

# Encryption - Test key for unit tests only
# DO NOT use this key in production!
DATA_ENCRYPTION_KEY="dGVzdC1rZXktZm9yLXVuaXQtdGVzdHMtb25seTox"

# LLM Configuration - Fake keys for testing
LLM_PROVIDER=qwen
LLM_API_KEY=fake-test-key-for-unit-testing
LLM_MODEL=qwen-turbo

# Database - Use in-memory SQLite for tests
DATABASE_URL=sqlite:///:memory:

# Redis - Use fake Redis for tests
REDIS_URL=redis://localhost:6379/15

# Security
SECRET_KEY=test-secret-key-for-unit-testing-only-do-not-use-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Logging
LOG_LEVEL=WARNING

# Feature Flags
ENABLE_CACHING=false
ENABLE_RATE_LIMITING=false
ENABLE_ENCRYPTION=true

# External Services - Disable in tests
PDF_PROCESSING_ENABLED=false
EMAIL_NOTIFICATIONS_ENABLED=false
WEWORK_NOTIFICATIONS_ENABLED=false
