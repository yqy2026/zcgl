{
  "test_runner": {
    "timeout": {
      "backend": 1800,
      "frontend": 1200,
      "overall": 3600
    },
    "parallel": true,
    "max_workers": 2,
    "retry_failed": true,
    "retry_count": 2
  },
  "backend": {
    "python_version": "3.12",
    "package_manager": "uv",
    "test_framework": "pytest",
    "coverage": {
      "enabled": true,
      "threshold": 80,
      "source_dirs": ["src"],
      "exclude_dirs": ["tests", "migrations", "__pycache__"],
      "exclude_patterns": ["*/test_*.py", "*/tests/*"],
      "report_formats": ["xml", "html", "term-missing"],
      "fail_under": 80
    },
    "pytest": {
      "testpaths": ["tests"],
      "python_files": ["test_*.py", "*_test.py"],
      "python_classes": ["Test*"],
      "python_functions": ["test_*"],
      "markers": [
        "unit: Unit tests",
        "integration: Integration tests",
        "e2e: End-to-end tests",
        "slow: Slow running tests",
        "network: Tests requiring network access"
      ],
      "options": {
        "verbose": true,
        "tb": "short",
        "strict_markers": true,
        "strict_config": true,
        "maxfail": 10,
        "dist": "loadfile",
        "numprocesses": "auto"
      }
    },
    "quality_checks": {
      "ruff": {
        "enabled": true,
        "fix": false,
        "select": ["E", "F", "I", "W", "UP"],
        "line_length": 88
      },
      "mypy": {
        "enabled": true,
        "strict": true,
        "ignore_missing_imports": false,
        "warn_return_any": true,
        "warn_unused_configs": true
      },
      "bandit": {
        "enabled": true,
        "confidence": "medium",
        "severity": "medium"
      },
      "safety": {
        "enabled": true,
        "ignore": []
      }
    }
  },
  "frontend": {
    "node_version": "20",
    "package_manager": "npm",
    "test_framework": "jest",
    "coverage": {
      "enabled": true,
      "threshold": 70,
      "source_dirs": ["src"],
      "exclude_dirs": ["node_modules", "dist", "build", "coverage"],
      "exclude_patterns": ["*.test.*", "*.spec.*", "*.stories.*"],
      "report_formats": ["lcov", "json", "html", "text"],
      "collect_coverage_from": [
        "src/**/*.{ts,tsx,js,jsx}",
        "!src/**/*.d.ts",
        "!src/**/*.stories.{ts,tsx}",
        "!src/**/index.{ts,tsx}"
      ],
      "coverage_threshold": {
        "global": {
          "branches": 70,
          "functions": 70,
          "lines": 70,
          "statements": 70
        }
      }
    },
    "jest": {
      "testEnvironment": "jsdom",
      "setupFilesAfterEnv": ["<rootDir>/src/test/setup.ts"],
      "testMatch": [
        "**/__tests__/**/*.(ts|tsx|js)",
        "**/*.(test|spec).(ts|tsx|js)"
      ],
      "collectCoverageFrom": [
        "src/**/*.(ts|tsx|js)",
        "!src/**/*.d.ts",
        "!src/**/*.stories.(ts|tsx)"
      ],
      "coverageDirectory": "coverage",
      "coverageReporters": ["text", "lcov", "html", "json"],
      "testTimeout": 10000,
      "maxWorkers": "50%",
      "cache": true,
      "transform": {
        "^.+\\.(ts|tsx)$": "ts-jest"
      },
      "moduleNameMapping": {
        "^@/(.*)$": "<rootDir>/src/$1"
      }
    },
    "quality_checks": {
      "eslint": {
        "enabled": true,
        "fix": false,
        "config_file": ".eslintrc.js",
        "ignore_patterns": ["build/", "dist/", "node_modules/"]
      },
      "prettier": {
        "enabled": true,
        "check": true,
        "config_file": ".prettierrc"
      },
      "typescript": {
        "enabled": true,
        "no_emit": true,
        "strict": true
      }
    }
  },
  "reporting": {
    "formats": ["json", "html", "junit"],
    "output_dir": "test-results",
    "include_coverage": true,
    "include_performance": true,
    "generate_summary": true,
    "upload_to_codecov": false,
    "upload_to_sonar": false
  },
  "performance": {
    "enabled": true,
    "slow_test_threshold": 5.0,
    "memory_threshold": 500,
    "benchmark": {
      "enabled": true,
      "compare_with_baseline": true,
      "save_baseline": true,
      "baseline_file": "benchmark-baseline.json"
    },
    "profiling": {
      "enabled": false,
      "memory_profiler": false,
      "cpu_profiler": false
    }
  },
  "notifications": {
    "enabled": false,
    "channels": {
      "slack": {
        "enabled": false,
        "webhook_url": "",
        "channel": "#dev-alerts",
        "on_failure": true,
        "on_success": false
      },
      "email": {
        "enabled": false,
        "recipients": [],
        "on_failure": true,
        "on_success": false
      }
    }
  },
  "cleanup": {
    "enabled": true,
    "cleanup_after_run": false,
    "keep_last_n_runs": 5,
    "artifacts_to_clean": [
      ".coverage",
      "htmlcov/",
      "coverage/",
      "test-results.xml",
      "*.log"
    ]
  },
  "hooks": {
    "pre_test": [
      "echo 'Starting tests...' && date"
    ],
    "post_test": [
      "echo 'Tests completed' && date"
    ],
    "pre_backend": [
      "cd backend && uv sync --dev"
    ],
    "post_backend": [
      "echo 'Backend tests completed'"
    ],
    "pre_frontend": [
      "cd frontend && npm ci"
    ],
    "post_frontend": [
      "echo 'Frontend tests completed'"
    ]
  },
  "environment": {
    "backend": {
      "DATABASE_URL": "sqlite:///./test.db",
      "ENVIRONMENT": "testing",
      "SECRET_KEY": "test_secret_key",
      "CORS_ORIGINS": ["http://localhost:3000"]
    },
    "frontend": {
      "NODE_ENV": "test",
      "CI": "true"
    }
  },
  "integrations": {
    "github_actions": {
      "enabled": true,
      "auto_comment_pr": true,
      "upload_artifacts": true,
      "quality_gate": true
    },
    "sonarqube": {
      "enabled": false,
      "server_url": "",
      "project_key": "",
      "organization": ""
    },
    "codecov": {
      "enabled": false,
      "token": "",
      "flags": ["backend", "frontend"]
    }
  }
}