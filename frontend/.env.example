# ============================================
# 前端环境配置示例
# ============================================

# 应用基础信息
VITE_APP_TITLE=地产资产管理系统
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=土地物业资产管理系统

# API配置
VITE_API_BASE_URL=http://localhost:8002/api/v1
VITE_API_TIMEOUT=30000
VITE_API_RETRY_TIMES=3

# 应用配置
VITE_PUBLIC_PATH=/
VITE_BASE_URL=/

# 功能开关
VITE_ENABLE_MOCK=false
VITE_ENABLE_DEVTOOLS=true
VITE_ENABLE_ANALYTICS=false

# 地图配置（可选）
VITE_AMAP_KEY=your-amap-key
VITE_BAIDU_MAP_KEY=your-baidu-map-key

# 文件上传配置
VITE_UPLOAD_SIZE_LIMIT=52428800
VITE_SUPPORTED_FORMATS=pdf,xlsx,xls

# 主题配置
VITE_PRIMARY_COLOR=#1890ff
VITE_THEME_MODE=light

# 缓存配置
VITE_CACHE_TIMEOUT=300000
VITE_ENABLE_OFFLINE=true

# 性能配置
VITE_ENABLE_CHUNK_ANALYSIS=false
VITE_SOURCEMAP=false

# 第三方服务
VITE_SENTRY_DSN=your-sentry-dsn
VITE_GOOGLE_ANALYTICS_ID=your-ga-id

# 开发配置
VITE_DEV_HOST=0.0.0.0
VITE_DEV_PORT=5173
VITE_DEV_PROXY_TIMEOUT=120000