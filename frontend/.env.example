# =============================================
# API Configuration
# =============================================
VITE_API_BASE_URL=http://127.0.0.1:8002/api/v1

# API Timeout (milliseconds)
VITE_API_TIMEOUT=30000

# =============================================
# Application Configuration
# =============================================
VITE_APP_VERSION=1.0.0
