{
  "name": "land-property-asset-management-frontend",
  "version": "1.0.0",
  "private": true,
  "types": "index.d.ts",
  "dependencies": {
    "@ant-design/icons": "^6.0.0",
    "@ant-design/plots": "^2.0.0",
    "@hookform/resolvers": "^3.3.2",
    "@tanstack/react-query": "^5.90.7",
    "antd": "^6.2.0",
    "axios": "^1.13.5",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.10",
    "framer-motion": "^12.23.26",
    "lodash": "^4.17.21",
    "pinyin-pro": "^3.28.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.48.2",
    "react-router-dom": "^6.20.1",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.0",
    "@babel/plugin-transform-runtime": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@faker-js/faker": "^10.1.0",
    "@playwright/test": "^1.53.2",
    "@tanstack/react-virtual": "^3.13.12",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.1",
    "@types/lodash": "^4.14.202",
    "@types/node": "^20.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@typescript/native-preview": "7.0.0-dev.20260214.1",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.16",
    "@vitest/ui": "^4.0.16",
    "identity-obj-proxy": "^3.0.0",
    "jsdom": "^27.3.0",
    "msw": "^2.12.4",
    "oxfmt": "^0.32.0",
    "oxlint": "^1.47.0",
    "playwright": "^1.53.2",
    "rollup-plugin-visualizer": "^6.0.5",
    "stylelint": "^16.26.1",
    "stylelint-config-css-modules": "^4.5.1",
    "stylelint-config-standard": "^39.0.1",
    "stylelint-order": "^7.0.1",
    "terser": "^5.44.1",
    "tsd": "^0.28.1",
    "type-coverage": "^2.29.7",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^4.0.16"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:ci": "vitest --run --coverage",
    "test:watch": "vitest --watch",
    "test:single": "vitest run",
    "test:style-guards": "vitest run src/utils/__tests__/styleGuardScripts.test.ts",
    "test:debug": "vitest --inspect-brk --no-coverage",
    "test:update": "vitest -u",
    "test:related": "vitest related",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:ci": "playwright test --reporter=dot",
    "e2e:report": "playwright show-report ../test-results/frontend/playwright/reports/html",
    "lint": "oxlint --config .oxlintrc.json --deny-warnings --max-warnings=0 --disable-unicorn-plugin --react-plugin --import-plugin --jsx-a11y-plugin src",
    "lint:fix": "oxlint --config .oxlintrc.json --fix --deny-warnings --max-warnings=0 --disable-unicorn-plugin --react-plugin --import-plugin --jsx-a11y-plugin src",
    "format": "oxfmt --config .oxfmtrc.json --write \"src/**/*.{ts,tsx,json,css,scss,md}\"",
    "format:check": "oxfmt --config .oxfmtrc.json --check \"src/**/*.{ts,tsx,json,css,scss,md}\"",
    "format:all": "oxfmt --config .oxfmtrc.json --write .",
    "type-check": "tsgo --noEmit",
    "type-check:e2e": "tsgo -p tsconfig.e2e.json --noEmit",
    "type-coverage": "type-coverage -p tsconfig.json --detail",
    "type-coverage:check": "type-coverage -p tsconfig.json --atLeast 95",
    "tsd": "tsd",
    "guard:ui": "corepack pnpm scan:lint-disable && corepack pnpm scan:px:all-strict && corepack pnpm verify:token-sync",
    "guard:ui:report": "corepack pnpm scan:lint-disable:report && corepack pnpm scan:px:report && corepack pnpm verify:token-sync:report",
    "guard:ui:ci": "node scripts/scan-lint-disable-comments.js --json-file ../reports/frontend/lint-disable-report.json && node scripts/scan-style-px.js --fail-on-module --fail-on-non-token --fail-on-token --json-file ../reports/frontend/style-px-report.json && node scripts/verify-token-sync.js --json-file ../reports/frontend/token-sync-report.json",
    "check": "corepack pnpm lint && corepack pnpm guard:ui && corepack pnpm type-check && corepack pnpm type-check:e2e && corepack pnpm format:check",
    "check:fix": "corepack pnpm lint:fix && corepack pnpm format",
    "lint:css": "stylelint \"**/*.{css,scss}\"",
    "lint:css:fix": "stylelint \"**/*.{css,scss}\" --fix",
    "lint:a11y": "oxlint --config .oxlintrc.json --deny-warnings --max-warnings=0 --jsx-a11y-plugin src",
    "scan:px": "node scripts/scan-style-px.js",
    "scan:px:strict": "node scripts/scan-style-px.js --fail-on-module --fail-on-non-token",
    "scan:px:all-strict": "node scripts/scan-style-px.js --fail-on-module --fail-on-non-token --fail-on-token",
    "scan:px:report": "node scripts/scan-style-px.js --json-file ../reports/frontend/style-px-report.json",
    "scan:lint-disable": "node scripts/scan-lint-disable-comments.js",
    "scan:lint-disable:report": "node scripts/scan-lint-disable-comments.js --json-file ../reports/frontend/lint-disable-report.json",
    "verify:token-sync": "node scripts/verify-token-sync.js",
    "verify:token-sync:report": "node scripts/verify-token-sync.js --json-file ../reports/frontend/token-sync-report.json",
    "test:a11y": "vitest run --coverage --reporter=verbose --run",
    "audit:ui": "corepack pnpm lint && corepack pnpm guard:ui && corepack pnpm lint:css && corepack pnpm type-check && corepack pnpm type-check:e2e",
    "audit:full": "corepack pnpm lint && corepack pnpm guard:ui && corepack pnpm lint:css && corepack pnpm type-check && corepack pnpm type-check:e2e && corepack pnpm test",
    "audit:full:coverage": "corepack pnpm lint && corepack pnpm guard:ui && corepack pnpm lint:css && corepack pnpm type-check && corepack pnpm type-check:e2e && corepack pnpm test:ci",
    "diagnose": "node scripts/diagnose/run-diagnostics.js",
    "diagnose:headful": "HEADLESS=false corepack pnpm diagnose",
    "diagnose:routes": "PAGES=/dashboard,/assets/list,/rental/contracts corepack pnpm diagnose",
    "diagnose:report": "start ../test-results/frontend/diagnostics/diagnostic-report-*.html"
  },
  "typeCoverage": {
    "atLeast": 95,
    "ignoreCatch": true,
    "ignoreFiles": [
      "src/__tests__/**",
      "src/components/**/__tests__/**",
      "src/test/**"
    ]
  },
  "tsd": {
    "directory": "tsd"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
