  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:ci": "vitest --run --coverage",
    "test:watch": "vitest --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "type-coverage": "type-coverage -p tsconfig.json --detail",
    "type-coverage:check": "type-coverage -p tsconfig.json --atLeast 95",
    "tsd": "tsd"
  },
  "typeCoverage": {
    "atLeast": 95,
    "ignoreCatch": true,
    "ignoreFiles": [
      "src/__tests__/**",
      "src/components/**/__tests__/**",
      "src/test/**"
    ]
  },
  "tsd": {
    "directory": "tsd"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
