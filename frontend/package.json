{
  "name": "land-property-asset-management-frontend",
  "version": "1.0.0",
  "private": true,
  "types": "index.d.ts",
  "dependencies": {
    "@ant-design/icons": "^6.0.0",
    "@ant-design/plots": "^2.0.0",
    "@hookform/resolvers": "^3.3.2",
    "@tanstack/react-query": "^5.90.7",
    "antd": "^6.2.0",
    "axios": "^1.6.2",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.10",
    "framer-motion": "^12.23.26",
    "lodash": "^4.17.21",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.48.2",
    "react-router-dom": "^6.20.1",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.0",
    "@babel/plugin-transform-runtime": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@emotion/jest": "^11.11.0",
    "@faker-js/faker": "^10.1.0",
    "@tanstack/react-virtual": "^3.13.12",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.1",
    "@types/lodash": "^4.14.202",
    "@types/node": "^20.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.44.1",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.16",
    "@vitest/ui": "^4.0.16",
    "babel-jest": "^29.7.0",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-css-modules": "^2.12.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "identity-obj-proxy": "^3.0.0",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-watch-typeahead": "^2.2.2",
    "jsdom": "^27.3.0",
    "msw": "^2.12.4",
    "prettier": "^3.7.4",
    "rollup-plugin-visualizer": "^6.0.5",
    "stylelint": "^16.26.1",
    "stylelint-config-css-modules": "^4.5.1",
    "stylelint-config-standard": "^39.0.1",
    "stylelint-order": "^7.0.1",
    "terser": "^5.44.1",
    "tsd": "^0.28.1",
    "type-coverage": "^2.29.7",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^4.0.16"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:ci": "vitest --run --coverage",
    "test:watch": "vitest --watch",
    "test:single": "vitest run",
    "test:debug": "vitest --inspect-brk --no-coverage",
    "test:update": "vitest -u",
    "test:related": "vitest related",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css,scss,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css,scss,md}\"",
    "format:all": "prettier --write .",
    "type-check": "tsc --noEmit",
    "type-coverage": "type-coverage -p tsconfig.json --detail",
    "type-coverage:check": "type-coverage -p tsconfig.json --atLeast 95",
    "tsd": "tsd",
    "check": "npm run lint && npm run type-check && npm run format:check",
    "check:fix": "npm run lint:fix && npm run format",
    "lint:css": "stylelint \"**/*.{css,scss}\"",
    "lint:css:fix": "stylelint \"**/*.{css,scss}\" --fix",
    "lint:a11y": "eslint src --ext .ts,.tsx --plugin jsx-a11y",
    "test:a11y": "vitest run --coverage --reporter=verbose --run",
    "audit:ui": "npm run lint && npm run lint:css && npm run type-check",
    "audit:full": "npm run lint && npm run lint:css && npm run type-check && npm run test:ci"
  },
  "typeCoverage": {
    "atLeast": 95,
    "ignoreCatch": true,
    "ignoreFiles": [
      "src/__tests__/**",
      "src/components/**/__tests__/**",
      "src/test/**"
    ]
  },
  "tsd": {
    "directory": "tsd"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
