{
  "name": "api-consistency-checker",
  "version": "1.0.0",
  "description": "API一致性检查工具",
  "scripts": {
    "check-api": "node frontend/scripts/check-api-consistency.js",
    "check-backend-api": "cd backend && python scripts/api_consistency_check.py . ../frontend",
    "check-all-api": "npm run check-backend-api && npm run check-api",
    "dev": "concurrently \"npm run check-api -- --watch\" \"npm run check-backend-api\"",
    "validate": "npm run check-all-api",
    "fix:api-format": "prettier --write \"frontend/src/services/*.ts\" \"backend/src/api/v1/*.py\"",
    "lint:api": "eslint frontend/src/services --ext .ts"
  },
  "devDependencies": {
    "concurrently": "^7.6.0",
    "prettier": "^2.8.8",
    "eslint": "^8.40.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}