# 开发环境配置
# 数据库配置
DATABASE_URL=sqlite:///./database/data/land_property.db

# 安全配置 - 生产环境必须更改为强密钥
# 注意：这是一个开发环境密钥，生产环境必须使用不同的强密钥
SECRET_KEY=UACxTNSaBeioMgFOcXIFROTpy3BsGFDcVBn8gKIMbCw

# API配置
API_HOST=127.0.0.1
API_PORT=8002
API_DEBUG=true

# 前端配置
VITE_API_BASE_URL=http://127.0.0.1:8002
VITE_APP_TITLE=经营性资产管理系统

# 日志配置
LOG_LEVEL=DEBUG
LOG_FILE=logs/application/dev.log

# 缓存配置
CACHE_ENABLED=true
CACHE_TTL=300

# PDF处理配置
PDF_MAX_SIZE=50MB
OCR_ENABLED=true
# OCR 引擎配置（PaddleOCR）
OCR_LANG=ch
OCR_USE_GPU=false
OCR_ENABLE_MKLDNN=true
OCR_SHOW_LOG=false
OCR_USE_ANGLE_CLS=true
OCR_USE_TEXTLINE_ORIENTATION=true
OCR_DET_DB_THRESH=0.3
OCR_DET_LIMIT_SIDE_LEN=960
OCR_REC_BATCH_NUM=6
OCR_DROP_SCORE=0.5

# LLM/ChatGLM3 设置（开发环境）
CHATGLM3_API_URL=http://127.0.0.1:8008/generate
CHATGLM3_MAX_TOKENS=1200
CHATGLM3_TEMPERATURE=0.2
CHATGLM3_TIMEOUT=25
LLM_TRIGGER_THRESHOLD=0.65

# 如果使用本地 Ollama 服务（默认端口 11434），设置模型名称
# 例如：qwen3:4b 或 qwen2:4b-instruct
OLLAMA_MODEL=
