# 开发环境配置
# 数据库配置
DATABASE_URL=sqlite:///./database/data/land_property.db

# API配置
API_HOST=127.0.0.1
API_PORT=8002
API_DEBUG=true

# 前端配置
VITE_API_BASE_URL=http://127.0.0.1:8002
VITE_APP_TITLE=经营性资产管理系统

# 日志配置
LOG_LEVEL=DEBUG
LOG_FILE=logs/application/dev.log

# 缓存配置
CACHE_ENABLED=true
CACHE_TTL=300

# PDF处理配置
PDF_MAX_SIZE=50MB
OCR_ENABLED=true