# ============================================
# 地产资产管理系统 - 环境配置示例
# ============================================

# 应用基础配置
APP_NAME=Land Property Asset Management
APP_VERSION=1.0.0
APP_DESCRIPTION=土地物业资产管理系统
APP_DEBUG=false

# 服务配置
HOST=0.0.0.0
PORT=8002
WORKERS=4

# 数据库配置
DATABASE_URL=sqlite:///./data/land_property.db
# DATABASE_URL=postgresql://user:password@localhost:5432/land_property
# DATABASE_URL=mysql://user:password@localhost:3306/land_property

# Redis配置（可选）
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# 安全配置
SECRET_KEY=your-super-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# 开发模式配置
DEV_MODE=false
DEV_CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# 文件上传配置
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=52428800  # 50MB
ALLOWED_EXTENSIONS=pdf,xlsx,xls

# PDF处理配置
PDF_PROCESSING_TIMEOUT=300
OCR_ENABLED=true
OCR_LANGUAGE=chi_sim+eng

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
LOG_ROTATION=daily
LOG_RETENTION=30

# 监控配置
HEALTH_CHECK_INTERVAL=30
METRICS_ENABLED=true
PERFORMANCE_MONITORING=true

# 邮件配置（可选）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_TLS=true

# 第三方服务配置
# 百度OCR API
BAIDU_OCR_APP_ID=your-baidu-app-id
BAIDU_OCR_API_KEY=your-baidu-api-key
BAIDU_OCR_SECRET_KEY=your-baidu-secret-key

# 阿里云OSS（可选）
OSS_ACCESS_KEY_ID=your-oss-access-key-id
OSS_ACCESS_KEY_SECRET=your-oss-access-key-secret
OSS_BUCKET=your-bucket-name
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com

# 微信小程序（可选）
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret