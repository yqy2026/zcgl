# 生产环境配置模板
# 使用前请复制为 .env 并修改所有敏感配置

# =============================================================================
# 🔐 安全配置 - 必须修改
# =============================================================================

# JWT密钥 - 使用强随机密钥，不要使用示例密钥
# 生成方法: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY="REPLACE-WITH-STRONG-RANDOM-KEY-32-CHARS-MINIMUM"

# 环境标识
ENVIRONMENT=production

# =============================================================================
# 🗄️ 数据库配置
# =============================================================================

# 生产数据库连接 - 推荐使用PostgreSQL或MySQL
DATABASE_URL="postgresql://username:password@host:port/database_name"
# DATABASE_URL="mysql://username:password@host:port/database_name"

# 禁用数据库查询日志（生产环境）
DATABASE_ECHO=false

# =============================================================================
# 🌐 API配置
# =============================================================================

# API服务器配置
HOST=0.0.0.0
PORT=8002
DEBUG=false
RELOAD=false

# =============================================================================
# 🔒 CORS配置 - 限制具体域名
# =============================================================================

# 只允许指定域名访问，不要使用通配符
CORS_ORIGINS="https://yourdomain.com,https://app.yourdomain.com"

# =============================================================================
# 📁 文件上传配置
# =============================================================================

# 文件上传大小限制（MB）
MAX_FILE_SIZE=52428800  # 50MB

# 安全上传目录
UPLOAD_DIR="/var/uploads/land-property-assets"

# =============================================================================
# ��️ 缓存配置
# =============================================================================

# Redis配置（推荐）
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=0

# 缓存TTL设置
CACHE_TTL=3600
CACHE_PREFIX=zcgl_prod

# =============================================================================
# 📊 日志配置
# =============================================================================

# 日志级别（生产环境推荐WARNING或ERROR）
LOG_LEVEL=WARNING

# 日志文件路径
LOG_FILE="/var/log/land-property-management/app.log"

# =============================================================================
# 📈 性能监控
# =============================================================================

# 启用性能指标
ENABLE_METRICS=true

# 慢查询阈值（秒）
SLOW_QUERY_THRESHOLD=1.0

# =============================================================================
# 🛡️ 认证和安全设置
# =============================================================================

# JWT配置
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# 密码策略
MIN_PASSWORD_LENGTH=12
SESSION_EXPIRE_DAYS=30
MAX_FAILED_ATTEMPTS=5
LOCKOUT_DURATION=900  # 15分钟
MAX_CONCURRENT_SESSIONS=3

# 审计日志保留天数
AUDIT_LOG_RETENTION_DAYS=90

# =============================================================================
# 🤖 AI/LLM配置（可选）
# =============================================================================

# ChatGLM3配置（如使用）
CHATGLM3_API_URL=http://your-llm-service:8000/generate
CHATGLM3_MAX_TOKENS=1500
CHATGLM3_TEMPERATURE=0.2
CHATGLM3_TIMEOUT=30
LLM_TRIGGER_THRESHOLD=0.65

# =============================================================================
# 📧 通知配置（可选）
# =============================================================================

# SMTP配置（用于邮件通知）
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_USE_TLS=true

# =============================================================================
# 🔍 监控和告警配置
# =============================================================================

# 健康检查端点密钥
HEALTH_CHECK_SECRET=your-health-check-secret

# 监控配置
MONITORING_ENABLED=true
METRICS_ENDPOINT=/metrics

# 告警Webhook
ALERT_WEBHOOK_URL=https://hooks.slack.com/your-webhook-url

# =============================================================================
# 💾 备份配置
# =============================================================================

# 数据库备份配置
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"  # 每天凌晨2点
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH="/var/backups/land-property-management"

# =============================================================================
# 🚀 安全强化配置
# =============================================================================

# 请求限制
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60  # 秒

# 会话安全
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTP_ONLY=true
SESSION_COOKIE_SAMESITE=strict

# API版本
API_VERSION=v1

# =============================================================================
# ⚠️ 重要提醒
# =============================================================================

# 1. 使用前请替换所有REPLACE-WITH-*占位符
# 2. 确保所有密码和密钥都是强随机生成的
# 3. 配置适当的防火墙规则
# 4. 设置定期备份和监控
# 5. 定期轮换密钥和密码
# 6. 启用HTTPS（在生产环境中）
# 7. 配置适当的日志轮转
# 8. 定期检查和更新依赖包
