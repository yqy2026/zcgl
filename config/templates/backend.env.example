# 环境变量配置文件
# Environment Variables Configuration

# 开发模式配置
DEV_MODE=true

# 数据库配置
DATABASE_URL=sqlite:///./data/land_property.db
# PostgreSQL 示例（生产推荐）
# DATABASE_URL=postgresql://username:password@localhost:5432/land_property
# MySQL 示例
# DATABASE_URL=mysql://username:password@localhost:3306/land_property

# API配置
API_TITLE=土地物业资产管理系统
API_VERSION=2.0.0

# CORS配置 (生产环境应该限制具体域名)
CORS_ORIGINS=["*"]

# 日志配置
LOG_LEVEL=INFO

# Redis缓存配置（可选）
# REDIS_URL=redis://localhost:6379/0

# 安全配置
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# 文件上传配置
MAX_UPLOAD_SIZE=50MB

# PDF处理配置
PDF_PROCESSING_TIMEOUT=300
OCR_CONFIDENCE_THRESHOLD=0.8

# OCR 引擎配置（PaddleOCR）
OCR_LANG=ch
OCR_USE_GPU=false
OCR_ENABLE_MKLDNN=true
OCR_SHOW_LOG=false
OCR_USE_ANGLE_CLS=true
OCR_DET_DB_THRESH=0.3
OCR_DET_LIMIT_SIDE_LEN=960
OCR_REC_BATCH_NUM=6
OCR_DROP_SCORE=0.5

# 监控配置
MONITORING_ENABLED=true
METRICS_COLLECTION_INTERVAL=60
