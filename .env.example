# Root .env example (used by docker-compose)
# Copy to .env and fill with real values.

POSTGRES_DB=zcgl
POSTGRES_USER=zcgl_user
POSTGRES_PASSWORD=CHANGE_ME

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=REPLACE-WITH-SECURE-SECRET-KEY
# DATA_ENCRYPTION_KEY format: <base64_key>:1
DATA_ENCRYPTION_KEY=REPLACE-WITH-SECURE-ENCRYPTION-KEY:1
REQUIRE_ENCRYPTION=true

DATABASE_URL=postgresql+psycopg://USERNAME:PASSWORD@postgres:5432/zcgl
