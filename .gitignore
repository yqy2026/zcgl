.ruff_cache/
# 构建产物
*-report.json
*-report.xml

# ============================================
# Explicit Preserve Rules for Test Directories
# ============================================
# Always track pytest test files in standard test directories
!backend/tests/**/*.py
!tests/**/*.py
!frontend/src/**/__tests__/**/*.ts*
!frontend/src/**/*.test.ts*
!frontend/src/**/*.test.tsx
!frontend/src/**/*.spec.ts*

# ============================================
# Explicit Preserve Rules for Source Files
# ============================================
# Ensure legitimate source files with certain patterns are tracked
# Debug tools and utilities
!**/debug_*.py
!**/debug_*.ts
!**/debug_*.tsx
!**/utils/**/*debug*.py
!**/utils/**/*debug*.ts

# Backup and archive utilities (but not backup files)
!**/backup_service.py
!**/archive_*.py
!**/*_manager.py

# Configuration examples
!**/*.example
!**/*.example.*
!**/*.template
!**/*.template.*
lint-results.txt
