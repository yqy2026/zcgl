# ============================================
# 特殊保留规则（需要版本控制的文件）
# ============================================

# 保留空的目录结构
!uploads/.gitkeep
!logs/.gitkeep
!data/.gitkeep

# 保留示例配置文件
!.env.example
!.env.template
!config.example.js

# 保留文档
!README.md
!CHANGELOG.md
!CONTRIBUTING.md

# 保留许可证文件
!LICENSE
!LICENCE

# 保留包管理文件
!package.json
!package-lock.json
!requirements.txt
!pyproject.toml
!poetry.lock

# ============================================
# Project Cleanup & Maintenance Rules
# ============================================

# Prevent re-introduction of cleaned test files
/tools/
/test_contract.pdf
/dictionaries_page_test.png
/backend/single_page_test.pdf
/dashboard_optimization_screenshot.png

# Prevent temporary debug files from being committed
# Note: Allow legitimate debugging tools with "debug" in name
debug_*.tmp
debug_*.log
debug_*.bak
/temp_*
/test_*.py
/test_*.db
demo_*
sample_*
# Only ignore debug backups, not source files
*_debug.bak
*_debug.tmp

# 临时分析脚本（一次性使用）
backend/find_quick_wins.py
backend/find_quickest_wins.py
backend/find_all_quick_wins.py
backend/check_cache_coverage.py
backend/check_*_coverage.py
backend/find_*_wins.py
backend/analyze_*.py

# Prevent backup and archive files from being committed
# Note: Only ignore backup files with date patterns or common backup extensions
# Avoid ignoring legitimate source files with backup-related names
*.backup.*
*.archive.*
backup_*.*
*_backup_*.*
*.$(date +%Y%m%d)*
# Be more specific about _old and _orig to avoid false positives
*_old.py.bak
*_orig.py.bak

# Prevent IDE and editor backup files
*.bak
*.tmp
*.swp
*.swo
*~

