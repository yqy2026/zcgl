# ============================================
# 特殊保留规则（需要版本控制的文件）
# ============================================

# 保留空的目录结构
!uploads/.gitkeep
!logs/.gitkeep
!data/.gitkeep

# 保留示例配置文件
!.env.example
!.env.template
!config.example.js

# 保留文档
!README.md
!CHANGELOG.md
!CONTRIBUTING.md

# 保留许可证文件
!LICENSE
!LICENCE

# 保留包管理文件
!package.json
!package-lock.json
!requirements.txt
!pyproject.toml
!poetry.lock

# ============================================
# Project Cleanup & Maintenance Rules
# ============================================

# Prevent re-introduction of cleaned test files
/tools/
/test_contract.pdf
/dictionaries_page_test.png
/backend/single_page_test.pdf
/dashboard_optimization_screenshot.png

# Prevent temporary debug files from being committed
debug_*
temp_*
test_*
demo_*
sample_*
*_debug.*

# Prevent backup and archive files from being committed
*_backup.*
*_archive.*
*_$(date +%Y%m%d)*
*_old.*
*_orig.*

# Prevent IDE and editor backup files
*.bak
*.tmp
*.swp
*.swo
*~

