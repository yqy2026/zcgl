# 生产环境配置模板
# 复制此文件为 .env.production 并填入实际值

# 数据库配置
POSTGRES_DB=land_property
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql://postgres:your_secure_password_here@database:5432/land_property

# Redis配置
REDIS_URL=redis://redis:6379/0

# 应用安全配置
SECRET_KEY=your_very_secure_secret_key_here_at_least_32_characters
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# 前端配置
VITE_API_BASE_URL=http://your-domain.com:8001
VITE_APP_TITLE=土地物业资产管理系统

# 监控配置
GRAFANA_PASSWORD=your_grafana_password_here

# SSL证书配置（如果使用HTTPS）
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# 邮件配置（用于告警）
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_USER=your-email@domain.com
SMTP_PASSWORD=your_email_password
SMTP_FROM=noreply@your-domain.com

# 备份配置
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=your-backup-bucket
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# 性能配置
MAX_WORKERS=4
MAX_CONNECTIONS=100
CACHE_TTL=300

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=json
SENTRY_DSN=your_sentry_dsn_here

# 功能开关
ENABLE_MONITORING=true
ENABLE_BACKUP=true
ENABLE_SSL=false
ENABLE_RATE_LIMITING=true